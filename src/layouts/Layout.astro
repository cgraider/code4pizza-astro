---
import "../styles/global.css";

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="fa" dir="rtl" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

        <!-- Google Variable Fonts for clean Persian and Mono typography -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Space+Mono&family=Vazirmatn:wght@100..900&display=swap"
            rel="stylesheet"
        />

        <title>{title}</title>
    </head>
    <body class="bg-background text-foreground antialiased font-persian">
        <slot />
    </body>
</html>
